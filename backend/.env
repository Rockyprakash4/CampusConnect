# Database Configuration
# For SQLite (default, zero-setup):
DATABASE_URL=sqlite:///./campusconnect.db

# For MySQL (production/major project demo):
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/campusconnect

# JWT Configuration
JWT_SECRET=supersecretjwtkeyforcampusconnectapp2026
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Cloudinary Configuration (Optional - falls back to local storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Configuration for Email Notifications (Optional - falls back to console logging)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@campusconnect.com

# Frontend Configuration
FRONTEND_URL=http://localhost:8000

# Development Mode Settings
# Set to true to bypass email verification on registration for local dev
DEV_MODE=true

